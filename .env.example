# ============================================================
# Chat Room — Environment Variables
# ============================================================
# 复制此文件为 .env 并填入真实值:
#   cp .env.example .env
#
# 启动前必须设置的环境变量已标注 [必需]。
# 开发环境可使用默认值，生产环境务必全部替换。
# ============================================================

# --- Flask 应用密钥 [必需] ---
# 用于签名 Session Cookie，生产环境务必使用随机长字符串。
# 生成方式: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=

# --- MySQL 数据库 ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=chatroom
MYSQL_PASSWORD=           # [必需] 生产环境必须设置
MYSQL_DB=chatroom

# --- 反向代理 / 公网访问配置 ---
# Flask 内部监听 HTTP:9888，但通常由 Nginx 在公网以 HTTPS:443 反代。
# 设置这两个变量告诉 Flask 公网 URL，确保重定向、Cookie、WebSocket 正确。
#
# Nginx HTTPS 反代示例:
#   ALIAS_PROTOCOL=https
#   ALIAS_PORT=443
#
# 直接暴露（仅开发环境）:
#   ALIAS_PROTOCOL=http
#   ALIAS_PORT=9888
ALIAS_PROTOCOL=http
ALIAS_PORT=9888

# --- Cloudflare Turnstile 人机验证 ---
# 注册地址: https://www.cloudflare.com/products/turnstile/
# 开发测试可使用以下默认值（始终通过验证）：
#   TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- 邀请码 [必需] ---
# 用户注册时需要的邀请码，存储在数据库中为 Argon2id 哈希。
# 默认值为 "changeme"，生产环境务必修改。
INVITE_CODE=

# --- 会话安全 ---
# SESSION_COOKIE_SECURE 会根据 ALIAS_PROTOCOL 自动设置：
#   ALIAS_PROTOCOL=https → Secure=True  （Cookie 仅通过 HTTPS 发送）
#   ALIAS_PROTOCOL=http  → Secure=False （开发环境）
# SESSION_COOKIE_HTTPONLY=True
# SESSION_COOKIE_SAMESITE=Lax

# --- Flask ---
# 设为 1 启用调试模式（开发用，生产环境务必关闭）
FLASK_DEBUG=0
